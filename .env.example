# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
APP_URL="YOUR_APP_URL_HERE"

# DATABASE_URL: PostgreSQL connection string for Prisma.
DATABASE_URL="postgresql://medisahel_user:INSERT_SECURE_PASSWORD_HERE@postgres:5432/medisahel_db?schema=public"

# JWT_SECRET: Cryptographically strong secret key (minimum 64 characters) used for token signatures.
JWT_SECRET="INSERT_64_CHARACTERS_LONG_SECRET_HERE"
