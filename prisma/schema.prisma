datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Patient Directory
model Patient {
  id                 String               @id
  nom                String
  prenom             String
  sexe               String
  dateNaissance      DateTime
  telephone          String
  adresse            String
  profession         String
  groupeSanguin      String
  allergies          String?
  assurance          String               @default("Aucune") 
  photoUrl           String?
  contactUrgenceNom  String?
  contactUrgenceTel  String?
  isArchive          Boolean              @default(false)
  nationalite        String?
  lieuNaissance      String?
  ethnie             String?
  antecedents        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  appointments       Appointment[]
  hospitalizations   Hospitalization[]
  labTests           LabTest[]
  medicalRecords     MedicalRecord[]
  invoices           Invoice[]
  vitalSigns         VitalSigns[]
  attachments        Attachment[]
}

// 2. Schedule Appointments
model Appointment {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id])
  medecin    String
  date       String
  heure      String
  salle      String
  statut     String   @default("Confirmé") // "Confirmé", "En attente", "Réalisé", "Annulé"
  notes      String?
  createdAt  DateTime @default(now())
}

// 3. Complete Hospital Room Admissions
model Hospitalization {
  id                 String   @id @default(uuid())
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id])
  chambre            String
  lit                String
  service            String
  dateEntree         DateTime @default(now())
  dateSortie         DateTime?
  statut             String   @default("Occupé") // "Occupé", "Sorti", "Maintenance"
  temperature        Float?
  frequenceCard      Int?
  soinsInfirmiers    String[] @default([])
}

// 4. Laboratory examinations
model LabTest {
  id                 String   @id @default(uuid())
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id])
  nomAnalyse         String
  typeExamen         String
  dateDemande        DateTime @default(now())
  statut             String   @default("En attente") // "En attente", "Validé"
  resultatObtenu     String?
  biologisteValid    String?
  valeurReference    String?  @default("")
  alertCritique      Boolean  @default(false)
}

// 5. Medical Records (DME)
model MedicalRecord {
  id                 String   @id @default(uuid())
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id])
  motif              String
  diagnostic         String
  codeCIM10          String
  prescription       String
  notesCliniques     String
  pdfCertificatUrl   String?
  certificatDuree    Int?
  medecinSignature   String?
  examensDemandes    String[] @default([])
  createdAt          DateTime @default(now())
  prescriptions      Prescription[]
  attachments        Attachment[]
}

// 6. Pharmacy Stocks manager
model StockItem {
  id                 String   @id @default(uuid())
  designation        String
  categorie          String   @default("Médicament") // "Médicament", "Consommable", "Réactif"
  numeroLot          String   @unique
  quantite           Int
  seuilAlerte        Int      @default(5)
  datePeremption     DateTime
  fournisseur        String
  updatedAt          DateTime @updatedAt
  dispensations      DrugDispensation[]
}

// 7. HR Presences
model StaffPresence {
  id                 String   @id @default(uuid())
  staffId            String?  @default("staff_1")
  nomPrenom          String
  role               String
  date               String
  heureArrivee       String
  heureDepart        String?
  statut             String   @default("Présent") // "Présent", "Retard", "Absent"
}

// 8. Audits logs (Immutable records)
model AuditLog {
  id                 String   @id @default(uuid())
  timestamp          DateTime @default(now())
  user               String
  role               String
  action             String
  details            String
  ip                 String
  oldValue           String?  @default("")
  newValue           String?  @default("")
}

// 9. User Authentication accounts with active control and RBAC fields
model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  passwordHash       String
  salt               String   @default("")
  name               String
  role               String
  isActive           Boolean  @default(true)
  allowedIPs         String?
  allowedHoursStart  String?
  allowedHoursEnd    String?
  allowedModules     String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  sessions           UserSession[]
}

// 10. Financial Invoice System
model Invoice {
  id                 String   @id @default(uuid())
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id])
  patientNom         String
  designation        String
  montantTotal       Float
  montantAssurance   Float
  montantPatiente    Float
  statut             String   @default("Impayé") // "Payé", "Impayé", "Avoir"
  modePaiement       String?
  dateEmission       DateTime @default(now())
  datePaiement       DateTime?
  caissier           String?
  isAvoir            Boolean  @default(false)
  payments           Payment[]
}

// 11. Individual Payment trace
model Payment {
  id                 String   @id @default(uuid())
  invoiceId          String
  invoice            Invoice  @relation(fields: [invoiceId], references: [id])
  amount             Float
  mode               String
  date               DateTime @default(now())
  caissier           String
}

// 12. Mailing Dispatch Registry
model Mail {
  id                 String   @id @default(uuid())
  type               String // "Entrant", "Sortant"
  numeroCourrier     String   @unique // Auto format: COU-2026-xxxx
  expediteurDestinataire String
  objet              String
  dateReceptionEnvoi DateTime @default(now())
  serviceAffecte     String
  statutTraitement   String   @default("En attente") // "En attente", "En cours", "Traité", "Archivé"
}

// 13. Insurances partners (Mutuelles)
model Insurance {
  id                 String   @id @default(uuid())
  nom                String   @unique
  taux               Int      // e.g. 70 for 70% coverage
  description        String?
  isActive           Boolean  @default(true)
}

// 14. Notifications log
model Notification {
  id                 String   @id @default(uuid())
  message            String
  role               String?
  userId             String?
  isRead             Boolean  @default(false)
  createdAt          DateTime @default(now())
}

// 15. User session tracker
model UserSession {
  id                 String   @id @default(uuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  token              String   @unique
  ipAddress          String
  loginTime          DateTime @default(now())
  lastSeen           DateTime @updatedAt
  isActive           Boolean  @default(true)
}

// 16. Persistent system branding and metadata config
model SystemSettings {
  id                 String   @id @default(uuid())
  name               String   @unique @default("Medishahel Settings")
  valueJson          String   // Stringified JSON payload structure
}

// 17. Real-time clinic Bed allocations
model BedManagement {
  id                 String   @id @default(uuid())
  bedCode            String   @unique
  chambre            String
  service            String
  patientId          String?
  patientNom         String?
  statut             String   @default("Disponible") // "Disponible", "Occupé", "Maintenance"
  temperature        Float?
  frequenceCard      Int?
  soinsLogs          String[] @default([])
}

// 18. Details of Drug dispenses inside pharmacy
model DrugDispensation {
  id                 String   @id @default(uuid())
  stockItemId        String
  stockItem          StockItem @relation(fields: [stockItemId], references: [id])
  patientNom         String
  quantite           Int
  dispensateur       String
  dateDispensation   DateTime @default(now())
}

// 19. Itemized recipe prescriptions
model Prescription {
  id                 String   @id @default(uuid())
  medicalRecordId    String
  medicalRecord      MedicalRecord @relation(fields: [medicalRecordId], references: [id])
  designation        String
  posologie          String
  duree              String
}

// 20. Constant Patients diagnostics
model VitalSigns {
  id                 String   @id @default(uuid())
  patientId          String
  patient            Patient  @relation(fields: [patientId], references: [id])
  source             String // "Triage", "Hospitalisation", "Consultation"
  temperature        Float?
  tension            String?
  frequenceCardiaque Int?
  poids              Float?
  spo2               Int?
  datePrise          DateTime @default(now())
}

// 21. Medical records pieces jointes
model Attachment {
  id                 String   @id @default(uuid())
  label              String
  url                String
  patientId          String?
  patient            Patient? @relation(fields: [patientId], references: [id])
  recordId           String?
  record             MedicalRecord? @relation(fields: [recordId], references: [id])
  createdAt          DateTime @default(now())
}
