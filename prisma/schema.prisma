datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  CASHIER
  PHARMACIST
  LAB_TECH
  HR
}

enum HospitalizationStatus {
  ADMITTED
  DISCHARGED
}

enum TransactionStatus {
  PAID
  UNPAID
  PARTIAL
}

enum TransactionType {
  INVOICE
  PAYMENT
}

enum LabStatus {
  PENDING
  COMPLETED
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

enum PayrollStatus {
  PAID
  PENDING
}

enum AppointmentStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Clinic {
  id          String   @id @default(uuid())
  name        String
  logoUrl     String?
  address     String?
  currency    String   @default("FCFA")
  themeColor  String   @default("#0f766e") // Default teal-700
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id                 String       @id @default(uuid())
  email              String       @unique
  passwordHash       String
  name               String
  role               Role         @default(DOCTOR)
  mustChangePassword Boolean      @default(true)
  clinicId           String
  clinic             Clinic       @relation(fields: [clinicId], references: [id])
  status             String       @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  attendances        Attendance[]
  payrolls           Payroll[]
}

model Patient {
  id             String            @id @default(uuid())
  firstName      String
  lastName       String
  nationalId     String            @unique
  dateOfBirth    String
  gender         String            @default("M") // M, F
  phone          String?
  email          String?
  bloodType      String?
  allergies      String?
  address        String?
  status         String            @default("ACTIVE") // ACTIVE, ARCHIVED
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  medicalRecords MedicalRecord[]
  hospitalizations Hospitalization[]
  transactions   Transaction[]
  labTests       LabTest[]
  appointments   Appointment[]
}

model MedicalRecord {
  id           String   @id @default(uuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId     String
  doctorName   String
  symptoms     String
  diagnosis    String
  prescription String
  notes        String?
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
}

model Hospitalization {
  id            String                @id @default(uuid())
  patientId     String
  patient       Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  bedNumber     String
  roomNumber    String
  admissionDate DateTime              @default(now())
  dischargeDate DateTime?
  reason        String
  status        HospitalizationStatus @default(ADMITTED)
  notes         String?
}

model Transaction {
  id            String            @id @default(uuid())
  patientId     String
  patient       Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type          TransactionType   @default(INVOICE)
  description   String
  amount        Float
  status        TransactionStatus @default(UNPAID)
  cashierId     String
  cashierName   String
  date          DateTime          @default(now())
  paymentMethod String            @default("CASH") // CASH, MOBILE_MONEY, CARD, INSURANCE
  createdAt     DateTime          @default(now())
}

model InventoryItem {
  id          String   @id @default(uuid())
  name        String
  sku         String   @unique
  category    String   @default("MEDICINE") // MEDICINE, CONSUMABLE, EQUIPMENT
  quantity    Int      @default(0)
  threshold   Int      @default(10) // Alert when under this quantity
  price       Float
  expiryDate  String?
  status      String   @default("IN_STOCK") // IN_STOCK, OUT_OF_STOCK, EXPIRED
  supplier    String?
  location    String?
  updatedAt   DateTime @updatedAt
}

model LabTest {
  id          String    @id @default(uuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  testName    String
  category    String    @default("BLOOD") // BLOOD, URINE, IMAGING, OTHER
  status      LabStatus @default(PENDING)
  results     String?
  requestedBy String
  performedBy String?
  date        DateTime  @default(now())
}

model Attendance {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String // YYYY-MM-DD
  checkIn   String? // HH:MM
  checkOut  String? // HH:MM
  status    AttendanceStatus @default(PRESENT)
  reason    String?
}

model Payroll {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  month      Int
  year       Int
  baseSalary Float
  bonuses    Float         @default(0)
  deductions Float         @default(0)
  netSalary  Float
  status     PayrollStatus @default(PENDING)
  payDate    DateTime?
}

model Appointment {
  id        String            @id @default(uuid())
  patientId String
  patient   Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId  String
  doctorName String
  date      String // YYYY-MM-DD
  time      String // HH:MM
  status    AppointmentStatus @default(CONFIRMED)
  notes     String?
}

model Document {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String?  // Can pack base64-ish mocks or paths
  fileType    String   @default("PDF") // PDF, DOCX, JPG
  category    String   @default("INCOMING") // INCOMING, OUTGOING, MEDICAL, ADMINISTRATIVE
  ownerId     String
  ownerName   String
  size        String   @default("0 KB")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  role      String
  action    String
  details   String
  timestamp DateTime @default(now())
}
